{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "shadpicture",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "dist/server/server.js",
  "build": {
    "command": "npm run build",
    "upload": {
      "format": "modules",
      "dir": "dist/server"
    }
  },
  "assets": {
    "bucket": "dist/client"
  }
}
